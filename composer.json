{
    "name": "a3rev/a3-hide-post-page-title",
    "description": "Adds a Hide Title checkbox option to the WordPress post and page editor for posts, pages and custom post types.",
    "authors": [
        {
            "name": "a3rev Software",
            "email": "admin@a3rev.com"
        }
    ],
    "config": {
        "optimize-autoloader": true
    },
    "require": {
        "php": ">=5.6|>=7.0"
    },
    "autoload": {
        "psr-4": {
          "A3Rev\\A3HidePostPageTitle\\": [ "src/", "admin/", "upgrade", "classes" ]
        },
        "classmap": [
            "classes/a3-hide-post-page-title-class.php",
            "classes/Editor_Sidebar.php"
        ]
    }
}